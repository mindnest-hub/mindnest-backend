// This is your Prisma schema file (v5),
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String?  @unique
  password      String
  ageGroup      String   @default("kids") // 'kids', 'teens', 'adults'
  role          String   @default("user")
  isVerified    Boolean  @default(false)
  verificationCode String?
  verificationExpires DateTime?
  xp            Int      @default(0)
  level         Int      @default(1)
  walletBalance Float    @default(0)
  fundedBalance Float    @default(0)
  streak        Int      @default(0)
  isElite       Boolean  @default(false)
  eliteExpires  DateTime?
  aiUnlimitedExpires DateTime?
  aiMessagesLeft Int      @default(10)
  hasUsedEarningsForElite Boolean @default(false)
  isAdmin       Boolean  @default(false)
  lastLogin     DateTime @default(now())
  moduleBalances Json     @default("{}")
  moduleEarnings Json     @default("{}")
  kycVerified    Boolean  @default(false)
  kycType        String?  // 'NIN', 'Gov ID', 'Passport'
  kycData        Json     @default("{}")
  badges         String   @default("[]") // Stored as JSON string for SQLite simplicity
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  aiConversations AiConversation[]
  rewardEvents    RewardEvent[]
  withdrawals     WithdrawalRequest[]
  transactions    Transaction[]
  civicResearch   CivicResearchData[]
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "REWARD", "WITHDRAWAL", "UPGRADE", "TOPUP"
  amount    Float
  module    String?  // Optional module name
  reason    String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@map("transactions")
}

model WithdrawalRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  status      String   @default("pending") // "pending", "approved", "rejected", "paid"
  bankDetails Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("withdrawal_requests")
}

model RewardEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  actionId  String   // Unique identifier for the reward action (e.g. "daily_bonus_2024_02_23")
  amount    Float
  reason    String?
  createdAt DateTime @default(now())

  @@unique([userId, actionId])
  @@map("reward_events")
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  response  String
  createdAt DateTime @default(now())

  @@map("ai_conversations")
}

model CivicResearchData {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  ageGroup      String   // e.g., 'kids', 'teens', 'adults'
  simulatorType String   // e.g., 'BUDGET', 'POLITICAL_TRICKS', 'CLASS_CAPTAIN'
  decisionData  Json     // The specific choices made
  createdAt     DateTime @default(now())

  @@map("civic_research_data")
}
